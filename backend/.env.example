PORT=4000

# MongoDB Atlas → Connect → Drivers.
# If you see querySrv ECONNREFUSED, use the STANDARD mongodb:// string (multiple :27017 hosts), NOT mongodb+srv://.
# Example SRV (needs working DNS):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/account-rbac-poc?retryWrites=true&w=majority
# Example STANDARD (no SRV lookup — use the full string from Atlas):
# MONGODB_URI=mongodb://USER:PASSWORD@cluster0-shard-00-00.xxx.mongodb.net:27017,cluster0-shard-00-01...
#
# Atlas checklist: Network Access → allow your IP (or 0.0.0.0/0 for dev), Database Access → user with read/write.
MONGODB_URI=

JWT_SECRET=change-this-to-a-long-random-string
FRONTEND_ORIGIN=http://localhost:5173
SEED_SUPER_ADMIN_EMAIL=admin@example.com
SEED_SUPER_ADMIN_PASSWORD=Admin@12345
SEED_SUPER_ADMIN_NAME=Super Admin
